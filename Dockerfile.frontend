FROM node:20-slim

ARG NEXT_PUBLIC_API_URL=http://127.0.0.1:8100
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

WORKDIR /app

# Install deps
COPY frontend/package.json frontend/package-lock.json* /app/
RUN npm install

# Copy frontend code
COPY frontend/ /app/

# Remove .env.local so NEXT_PUBLIC_API_URL from Docker ENV takes effect
RUN rm -f /app/.env.local

# Build
RUN npm run build

EXPOSE 3000

CMD ["npm", "start"]
