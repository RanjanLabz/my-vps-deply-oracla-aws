# Flow Kit - Environment Configuration
# Copy this file to .env and uncomment the values you want to change.
# All values have sensible defaults - you only need this for customization.

# ─── Server ──────────────────────────────────────────────────
# API_HOST=127.0.0.1
# API_PORT=8100
# WS_HOST=127.0.0.1
# WS_PORT=9222

# ─── Chrome ──────────────────────────────────────────────────
# Path to Chrome for Testing binary (auto-detected if using setup script)
# CHROME_BINARY=chrome_for_testing/chrome-win64/chrome.exe

# ─── Worker ──────────────────────────────────────────────────
# POLL_INTERVAL=5                  # seconds between queue checks
# VIDEO_POLL_INTERVAL=10           # seconds between video status checks
# MAX_RETRIES=5                    # max retries per request
# API_COOLDOWN=10                  # seconds between API calls (anti-spam)
# MAX_CONCURRENT_REQUESTS=5        # max parallel requests

# ─── Google Flow API ────────────────────────────────────────
# GOOGLE_API_KEY=AIzaSy...         # Google Flow API key
# RECAPTCHA_SITE_KEY=6LdsFiUs...  # reCAPTCHA site key

# ─── Redis (Upstash) ────────────────────────────────────────
# REDIS_URL=redis://default:...@adjusted-starfish-151150.upstash.io:6379

# ─── Cloudflare R2 Storage ──────────────────────────────────
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=flowkit-media-two
# R2_ENDPOINT_URL=https://...r2.cloudflarestorage.com
# R2_PUBLIC_URL=https://pub-...r2.dev

# ─── TTS (OmniVoice) ────────────────────────────────────────
# TTS_MODEL=k2-fsa/OmniVoice
# TTS_DEVICE=cpu                  # "cpu" recommended (mps produces gibberish)
# TTS_SAMPLE_RATE=24000

# ─── Review (Claude Vision) ─────────────────────────────────
# ANTHROPIC_API_KEY=sk-...
# REVIEW_MODEL=claude-haiku-4-5-20251001

# ─── Suno (Music Generation) ───────────────────────────────
# SUNO_API_KEY=...
# SUNO_BASE_URL=https://api.sunoapi.org
# SUNO_MODEL=V4
